# ============================================================
# LexSim backend environment (copy to server/.env before running)
# ============================================================

# ---- LLM ----
# Any OpenAI-compatible endpoint. Default config targets Alibaba Qwen.
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ---- ZEP network graph service ----
ZEP_API_KEY=

# ---- Server runtime (optional, defaults shown) ----
# PORT=3001
# CORS_ORIGIN=http://localhost:5173
# MAX_CONCURRENCY=5      # Max concurrent LLM calls per simulation round
# AGENT_TIMEOUT=60000    # Per-agent LLM call timeout (ms)
